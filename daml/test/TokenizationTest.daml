module Test.TokenizationTest where

import Daml.Script
import qualified DA.List as List
import qualified DA.Set as Set

import Asset.Token
import Asset.Role
import Asset.Whitelist
import Asset.Cash
import Asset.Dividend

-- A record to hold parties for convenience in tests
type Parties = {
  issuer: Party,
  investorA: Party,
  investorB: Party,
  unauthorized: Party,
  regulator: Party,
  custodian: Party
}

-- Main test suite for the tokenization workflow
tokenizationLifecycleTests = script do

  test "1. Asset Creation & Whitelisting" do
    parties <- setupParties
    -- Issuer creates the asset manager and corresponding whitelist
    (managerCid, whitelistCid) <- setupAssetAndWhitelist parties

    -- Issuer adds Investor A and B to the whitelist
    whitelistCid_1 <- submit parties.issuer do
      exerciseCmd whitelistCid AddApprovedParty with partyToAdd = parties.investorA
    whitelistCid_2 <- submit parties.issuer do
      exerciseCmd whitelistCid_1 AddApprovedParty with partyToAdd = parties.investorB

    -- Verify parties are on the list
    whitelist <- fromSomeNote "Whitelist contract not found" <$> queryContractId parties.issuer whitelistCid_2
    assert $ Set.member parties.investorA whitelist.approvedParties
    assert $ Set.member parties.investorB whitelist.approvedParties

    -- An unauthorized party cannot add anyone to the whitelist
    submitMustFail parties.unauthorized do
      exerciseCmd whitelistCid_2 AddApprovedParty with partyToAdd = parties.unauthorized

    -- Issuer can remove a party from the whitelist
    whitelistCid_3 <- submit parties.issuer do
      exerciseCmd whitelistCid_2 RemoveApprovedParty with partyToRemove = parties.investorB
    whitelist_final <- fromSomeNote "Whitelist contract not found after removal" <$> queryContractId parties.issuer whitelistCid_3
    assert $ not $ Set.member parties.investorB whitelist_final.approvedParties
    return ()

  test "2. Token Issuance" do
    parties <- setupParties
    (managerCid, whitelistCid) <- setupAssetAndWhitelist parties
    -- Add Investor A to whitelist
    whitelistCid' <- submit parties.issuer do exerciseCmd whitelistCid AddApprovedParty with partyToAdd = parties.investorA

    -- Issuer issues 1000.0 tokens to Investor A
    (holdingACid, newManagerCid) <- submit parties.issuer do
      exerciseCmd managerCid Issue with
        recipient = parties.investorA
        quantity = 1000.0
        whitelistCid = whitelistCid'

    -- Verify Investor A's holding and the new total supply
    holdingA <- fromSomeNote "HoldingA not found" <$> queryContractId parties.investorA holdingACid
    holdingA.quantity === 1000.0
    holdingA.asset.id.symbol === "TREF"

    manager <- fromSomeNote "Manager not found" <$> queryContractId parties.issuer newManagerCid
    manager.totalSupply === 1000.0

    -- Issuing to a non-whitelisted party must fail
    submitMustFail parties.issuer do
      exerciseCmd newManagerCid Issue with
        recipient = parties.unauthorized
        quantity = 500.0
        whitelistCid = whitelistCid'
    return ()

  test "3. Token Transfer" do
    parties <- setupParties
    (managerCid, whitelistCid) <- setupAssetAndWhitelist parties
    whitelistCid' <- submit parties.issuer do exerciseCmd whitelistCid AddApprovedParty with partyToAdd = parties.investorA
    whitelistCid'' <- submit parties.issuer do exerciseCmd whitelistCid' AddApprovedParty with partyToAdd = parties.investorB

    (holdingACid, managerCid1) <- submit parties.issuer do
      exerciseCmd managerCid Issue with recipient = parties.investorA, quantity = 1000.0, whitelistCid = whitelistCid''

    -- Investor A proposes to transfer 250.0 tokens to Investor B
    proposalCid <- submit parties.investorA do
      exerciseCmd holdingACid ProposeTransfer with newOwner = parties.investorB, quantity = 250.0

    -- Investor B accepts the transfer
    (newHoldingACid, holdingBCid) <- submit parties.investorB do
      exerciseCmd proposalCid AcceptTransfer with whitelistCid = whitelistCid''

    -- Verify the final balances are correct
    newHoldingA <- fromSomeNote "New HoldingA not found" <$> queryContractId parties.investorA newHoldingACid
    newHoldingA.quantity === 750.0

    holdingB <- fromSomeNote "HoldingB not found" <$> queryContractId parties.investorB holdingBCid
    holdingB.quantity === 250.0

    -- Attempt to transfer to a non-whitelisted party must fail
    submitMustFail do
      proposalCid2 <- submit parties.investorA do
        exerciseCmd newHoldingACid ProposeTransfer with newOwner = parties.unauthorized, quantity = 100.0
      submit parties.unauthorized do
        exerciseCmd proposalCid2 AcceptTransfer with whitelistCid = whitelistCid''

    -- Attempt to transfer more tokens than owned must fail
    submitMustFail do
      submit parties.investorA do
        exerciseCmd newHoldingACid ProposeTransfer with newOwner = parties.investorB, quantity = 800.0
    return ()

  test "4. Dividend Distribution" do
    parties <- setupParties
    (managerCid, whitelistCid) <- setupAssetAndWhitelist parties
    whitelistCid1 <- submit parties.issuer do exerciseCmd whitelistCid AddApprovedParty with partyToAdd = parties.investorA
    whitelistCid2 <- submit parties.issuer do exerciseCmd whitelistCid1 AddApprovedParty with partyToAdd = parties.investorB

    -- Issue tokens: 750 to A, 250 to B
    (holdingACid, managerCid1) <- submit parties.issuer do exerciseCmd managerCid Issue with recipient = parties.investorA, quantity = 750.0, whitelistCid = whitelistCid2
    (holdingBCid, managerCid2) <- submit parties.issuer do exerciseCmd managerCid1 Issue with recipient = parties.investorB, quantity = 250.0, whitelistCid = whitelistCid2

    -- Issuer sets up a dividend distribution of $500 total ($0.50 per share)
    let dividendAmount = 500.0
    let perShareRate = dividendAmount / 1000.0

    -- Issuer needs cash to pay the dividends
    cashIssuerCid <- submit parties.issuer do createCmd CashIssuer with issuer = parties.issuer
    cashHoldingCid <- submit parties.issuer do exerciseCmd cashIssuerCid IssueCash with owner = parties.issuer, amount = dividendAmount

    -- Issuer creates the distribution contract, funding it with the cash holding
    distributionCid <- submit parties.issuer do
      createCmd DividendDistribution with
        issuer = parties.issuer
        managerCid = managerCid2
        perShareRate = perShareRate
        paymentCid = cashHoldingCid
        claimedOwners = Set.empty

    -- Investor A claims their dividend (750 * 0.5 = $375)
    (newDistributionCid, investorACashCid) <- submitMulti [parties.investorA, parties.issuer] [] do
      exerciseCmd distributionCid ClaimDividend with holdingCid = holdingACid

    -- Verify Investor A's cash and that the distribution state is updated
    investorACash <- fromSomeNote "Investor A cash not found" <$> queryContractId parties.investorA investorACashCid
    investorACash.amount === 375.0
    newDistribution <- fromSomeNote "Distribution contract not found" <$> queryContractId parties.issuer newDistributionCid
    assert $ Set.member parties.investorA newDistribution.claimedOwners

    -- Investor B claims their dividend (250 * 0.5 = $125)
    (finalDistributionCid, investorBCashCid) <- submitMulti [parties.investorB, parties.issuer] [] do
      exerciseCmd newDistributionCid ClaimDividend with holdingCid = holdingBCid

    -- Verify Investor B's cash
    investorBCash <- fromSomeNote "Investor B cash not found" <$> queryContractId parties.investorB investorBCashCid
    investorBCash.amount === 125.0

    -- Attempting to claim twice must fail
    submitMustFail do
      submitMulti [parties.investorA, parties.issuer] [] do
        exerciseCmd finalDistributionCid ClaimDividend with holdingCid = holdingACid
    return ()

  test "5. Token Redemption" do
    parties <- setupParties
    (managerCid, whitelistCid) <- setupAssetAndWhitelist parties
    whitelistCid' <- submit parties.issuer do exerciseCmd whitelistCid AddApprovedParty with partyToAdd = parties.investorA

    (holdingACid, managerCid1) <- submit parties.issuer do
      exerciseCmd managerCid Issue with recipient = parties.investorA, quantity = 1000.0, whitelistCid = whitelistCid'

    let redemptionAmount = 200.0
    let redemptionPrice = 10.50
    let totalPayment = redemptionAmount * redemptionPrice

    -- Issuer needs cash to pay for the redemption
    cashIssuerCid <- submit parties.issuer do createCmd CashIssuer with issuer = parties.issuer
    issuerCashCid <- submit parties.issuer do exerciseCmd cashIssuerCid IssueCash with owner = parties.issuer, amount = totalPayment

    -- Investor A requests redemption; issuer co-signs to provide cash
    (remainingHoldingCid, _investorCashCid, finalManagerCid) <-
      submitMulti [parties.investorA, parties.issuer] [] do
        exerciseCmd holdingACid RequestRedemption with
          quantity = redemptionAmount
          managerCid = managerCid1
          cashToPayCid = issuerCashCid

    -- Verify Investor A's new token balance
    remainingHolding <- fromSomeNote "Remaining holding not found" <$> queryContractId parties.investorA remainingHoldingCid
    remainingHolding.quantity === 800.0

    -- Verify total supply is reduced on the manager contract
    finalManager <- fromSomeNote "Final manager not found" <$> queryContractId parties.issuer finalManagerCid
    finalManager.totalSupply === 800.0

    -- Verify issuer's cash holding was consumed
    queryContractId parties.issuer issuerCashCid >>= \c -> c === None
    return ()

-- Helper function to allocate all necessary parties for the tests
setupParties : Script Parties
setupParties = do
  issuer <- allocatePartyWithHint "Issuer" (PartyIdHint "Issuer_TokenizationTest")
  investorA <- allocatePartyWithHint "InvestorA" (PartyIdHint "InvestorA_TokenizationTest")
  investorB <- allocatePartyWithHint "InvestorB" (PartyIdHint "InvestorB_TokenizationTest")
  unauthorized <- allocatePartyWithHint "Unauthorized" (PartyIdHint "Unauthorized_TokenizationTest")
  regulator <- allocatePartyWithHint "Regulator" (PartyIdHint "Regulator_TokenizationTest")
  custodian <- allocatePartyWithHint "Custodian" (PartyIdHint "Custodian_TokenizationTest")
  return Parties with ..

-- Helper function to create the asset manager and whitelist contracts
setupAssetAndWhitelist : Parties -> Script (ContractId Manager, ContractId Whitelist)
setupAssetAndWhitelist parties = do
  let asset = AssetId with
        symbol = "TREF"
        issuer = parties.issuer
  managerCid <- submit parties.issuer do
    createCmd Manager with
      asset
      description = "Tokenized Real Estate Fund"
      custodian = parties.custodian
      regulator = parties.regulator
      totalSupply = 0.0
      observers = []
  whitelistCid <- submit parties.issuer do
    createCmd Whitelist with
      issuer = parties.issuer
      regulator = parties.regulator
      managerCid
      approvedParties = Set.empty
  return (managerCid, whitelistCid)

-- Helper for concise equality assertions
(===) : (Show a, Eq a) => a -> a -> Script ()
x === y = assertMsg ("Expected " <> show y <> ", but got " <> show x) (x == y)